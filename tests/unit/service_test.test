import pytest
from app.main import create_user
from unittest.mock import MagicMock


def test_create_user(mocker):
    mock_db = MagicMock()
    mock_user = {'email': 'test@example.com', 'password': 'strongpassword'}
    mocker.patch('app.main.SessionLocal', return_value=mock_db)
    create_user(mock_user)
    mock_db.add.assert_called_once()
    mock_db.commit.assert_called_once()


def test_create_user_invalid_email(mocker):
    mock_db = MagicMock()
    mock_user = {'email': 'invalid-email', 'password': 'strongpassword'}
    mocker.patch('app.main.SessionLocal', return_value=mock_db)
    with pytest.raises(ValueError):
        create_user(mock_user)